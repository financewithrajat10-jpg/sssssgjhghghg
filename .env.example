WORLD_CUP_YOUTUBE_SPIKE_ENABLED=true
WORLD_CUP_YOUTUBE_SCAN_MAX=100
WORLD_CUP_YOUTUBE_DISCOVERY_ENABLED=true
WORLD_CUP_YOUTUBE_DISCOVERY_INTERVAL_MINUTES=60
