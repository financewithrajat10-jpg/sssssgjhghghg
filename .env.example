# Google AI Studio / Gemini API key.
# Get one from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_ai_studio_key_here

# Optional: only use this when you have an NVIDIA TTS endpoint URL from build.nvidia.com
# or a self-hosted NVIDIA Speech/TTS NIM endpoint.
NVIDIA_API_KEY=your_nvidia_key_here
NVIDIA_TTS_URL=https://your-nvidia-tts-endpoint.example.com

# Optional: stock footage providers for Stock video mode.
# You can also save/switch these from Settings in the frontend.
PEXELS_API_KEY=your_pexels_key_here
PIXABAY_API_KEY=your_pixabay_key_here

# Optional local port.
PORT=3000

# Optional: comma-separated frontend origins allowed to call this backend.
# Use your Cloudflare Pages URL when the frontend is hosted separately.
ALLOWED_ORIGINS=https://money-printing-machine.pages.dev

# World Cup automated short-video pipeline.
# Optional Cloudflare R2 fallback upload target:
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_BASE_URL=https://your-public-r2-domain.example.com

# Google Drive upload target for World Cup output.
# Use either GOOGLE_SERVICE_ACCOUNT_JSON or GOOGLE_SERVICE_ACCOUNT_BASE64.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_SERVICE_ACCOUNT_BASE64=
GOOGLE_DRIVE_FOLDER_ID=your_shared_drive_or_folder_id
GOOGLE_DRIVE_MAKE_PUBLIC=false

# Optional World Cup pipeline tuning:
WORLD_CUP_UPLOAD_TARGET=google-drive
WORLD_CUP_MAX_VIDEOS_PER_DAY=3
WORLD_CUP_SCHEDULE_HOURS=9,15,21
WORLD_CUP_DEFAULT_LANGUAGE=en
GEMINI_LITE_TEXT_MODEL=gemini-3.1-flash-lite
GEMINI_RETRY_DELAYS=5000,10000,15000
WORLD_CUP_LITE_TEXT_MODEL=gemini-3.1-flash-lite
WORLD_CUP_SEARCH_MODEL=gemini-3.1-flash-lite
WORLD_CUP_SEARCH_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash
WORLD_CUP_WRITER_MODEL=gemini-3.1-flash-lite
WORLD_CUP_EVALUATOR_MODEL=gemini-3.1-flash-lite
WORLD_CUP_TTS_REWRITE_MODEL=gemini-3.1-flash-lite
WORLD_CUP_TTS_MODEL=gemini-3.1-flash-tts-preview
WORLD_CUP_AUDIO_SRT_MODEL=gemini-3.1-flash-lite
WORLD_CUP_AUDIO_SRT_FALLBACK_MODELS=gemini-2.5-flash
WORLD_CUP_GEMINI_RETRY_DELAYS=5000,10000,15000
WORLD_CUP_TOPICS=World Cup trap teams nobody wants in their group|Which host nation has the most pressure right now
