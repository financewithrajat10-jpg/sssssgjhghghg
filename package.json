{
  "name": "hindi-voice-studio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.mjs",
    "dev": "node server.mjs",
    "worldcup": "node worldcup/cli.mjs",
    "worldcup:dry": "node worldcup/cli.mjs --mode pre-tournament --topic \"World Cup chaos desk dry run\" --offline true --render false --upload false",
    "worldcup:controller": "node worldcup/azure-controller.mjs",
    "worldcup:controller:dry": "node worldcup/azure-controller.mjs --once --dry-run --offline",
    "worldcup:admin": "node worldcup/admin-dashboard.mjs",
    "worldcup:youtube-health": "node worldcup/youtube-health.mjs",
    "worldcup:controller:test": "node --test worldcup/azure-controller.intent.test.mjs worldcup/quality-v2.test.mjs worldcup/uploads.test.mjs worldcup/youtube.test.mjs"
  },
  "engines": {
    "node": ">=24"
  }
}
